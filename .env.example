# Developer LinkedIn > My apps > Auth 
CLIENT_ID=                  # Authentication keys > Client ID
CLIENT_SECRET=              # Authentication keys > Primary Client Secret

# Tokens OAuth2 — se generan ejecutando auth/linkedin_auth.py
ACCESS_TOKEN=               # Token de acceso (renovación automática al ejecutar main.py)
REFRESH_TOKEN=              # Token de refresco (caduca en 365 días >> Requiere renovación manual con auth/linkedin_auth.py)

# LinkedIn Campaign Manager 
ACCOUNT_ID=                 # ID de la cuenta publicitaria